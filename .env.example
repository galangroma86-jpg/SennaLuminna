# Salin file ini jadi ".env" lalu isi dengan API key asli dari dashboard Midtrans
# Dapatkan di: https://dashboard.midtrans.com/settings/config_info (mode Sandbox dulu untuk testing)

MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx

# Ganti jadi "true" hanya kalau sudah pakai Server Key & Client Key mode PRODUCTION (bukan Sandbox)
IS_PRODUCTION=false

# Port lokal untuk menjalankan server (boleh dibiarkan default)
PORT=3000
